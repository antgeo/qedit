<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>qedit — <%= Rails.root.basename %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, monospace;
      background: #1e1e1e;
      color: #ccc;
      overflow: hidden;
    }

    #app {
      display: grid;
      grid-template-rows: 40px 35px 1fr 24px;
      grid-template-columns: 260px 1fr;
      height: 100vh;
    }

    /* ── Top bar ── */
    #topbar {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 16px;
      background: #2d2d2d;
      border-bottom: 1px solid #3a3a3a;
      font-size: 13px;
    }

    #topbar .logo {
      font-weight: 700;
      color: #e8e8e8;
      letter-spacing: 0.5px;
    }

    #topbar .sep { color: #555; }

    #current-file {
      flex: 1;
      color: #9cdcfe;
      font-size: 12px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    #status-msg {
      font-size: 12px;
      color: #4ec9b0;
      min-width: 120px;
      text-align: right;
    }

    #btn-save {
      padding: 4px 14px;
      background: #0e639c;
      color: #fff;
      border: none;
      border-radius: 3px;
      font-size: 12px;
      cursor: pointer;
    }
    #btn-save:hover { background: #1177bb; }
    #btn-save:disabled { background: #444; color: #777; cursor: default; }

    /* ── Tab bar ── */
    #tab-bar {
      display: flex;
      align-items: stretch;
      background: #2d2d2d;
      border-bottom: 1px solid #3a3a3a;
      overflow-x: auto;
      overflow-y: hidden;
      scrollbar-width: thin;
      scrollbar-color: #555 transparent;
    }

    .tab {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0 10px 0 12px;
      min-width: 80px;
      max-width: 200px;
      font-size: 12px;
      color: #999;
      background: #2d2d2d;
      border-right: 1px solid #3a3a3a;
      cursor: pointer;
      white-space: nowrap;
      user-select: none;
      flex-shrink: 0;
    }
    .tab:hover { background: #383838; color: #ccc; }
    .tab.active { background: #1e1e1e; color: #fff; border-top: 2px solid #007acc; }

    .tab .tab-name { overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0; }
    .tab .tab-dirty { color: #e9c46a; font-size: 11px; flex-shrink: 0; }
    .tab .tab-close {
      font-size: 15px;
      line-height: 1;
      color: #555;
      padding: 1px 3px;
      border-radius: 3px;
      flex-shrink: 0;
    }
    .tab .tab-close:hover { background: #555; color: #fff; }

    /* ── Sidebar ── */
    #sidebar {
      grid-row: 2 / 4;
      background: #252526;
      border-right: 1px solid #3a3a3a;
      overflow-y: auto;
      padding: 8px 0;
    }

    .tree-item {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px;
      cursor: pointer;
      font-size: 13px;
      white-space: nowrap;
      user-select: none;
    }
    .tree-item:hover { background: #2a2d2e; }
    .tree-item.active { background: #094771; color: #fff; }

    .tree-item .icon { font-size: 11px; opacity: 0.7; }
    .tree-item .name { overflow: hidden; text-overflow: ellipsis; }

    .tree-dir > .tree-children { display: none; }
    .tree-dir.open > .tree-children { display: block; }

    /* ── Editor pane ── */
    #editor-pane {
      position: relative;
      overflow: hidden;
    }

    #monaco-editor {
      width: 100%;
      height: 100%;
    }

    #editor-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: #555;
      font-size: 14px;
      gap: 8px;
    }

    #editor-placeholder .hint {
      font-size: 12px;
      color: #3a3a3a;
    }

    #loading-overlay {
      display: none;
      position: absolute;
      inset: 0;
      background: rgba(30,30,30,0.7);
      align-items: center;
      justify-content: center;
      font-size: 13px;
      color: #9cdcfe;
      z-index: 10;
    }
    #loading-overlay.visible { display: flex; }

    /* ── Status bar ── */
    #status-bar {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 0 12px;
      background: #007acc;
      font-size: 12px;
      color: #fff;
    }

    #git-branch {
      display: flex;
      align-items: center;
      gap: 5px;
      opacity: 0.95;
    }

    #server-status {
      display: flex;
      align-items: center;
      gap: 5px;
      margin-left: auto;
      opacity: 0.95;
    }

    #server-status .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #4ec9b0;
      flex-shrink: 0;
    }

    #server-status.offline .dot  { background: #f48771; }
    #server-status.offline .label { opacity: 1; }

    #server-status .label {
      opacity: 0;
      transition: opacity 0.2s;
      font-size: 11px;
    }
  </style>
  <link rel="stylesheet" href="<%= qedit.monaco_path("min/vs/editor/editor.main.css") %>">
</head>
<body>
  <div id="app">
    <div id="topbar">
      <span class="logo">qedit</span>
      <span class="sep">|</span>
      <span id="current-file">No file open</span>
      <span id="status-msg"></span>
      <button id="btn-save" disabled>Save</button>
    </div>

    <div id="tab-bar"></div>

    <div id="sidebar">
      <div id="file-tree">
        <div class="tree-item" style="color:#555; font-size:12px; padding-left:12px;">Loading…</div>
      </div>
    </div>

    <div id="editor-pane">
      <div id="editor-placeholder">
        <div>Select a file to start editing</div>
        <div class="hint">Ctrl+S / Cmd+S to save</div>
      </div>
      <div id="monaco-editor" style="display:none;"></div>
      <div id="loading-overlay">Loading…</div>
    </div>

    <div id="status-bar">
      <% if @git_branch.present? %>
        <span id="git-branch">⎇ <%= @git_branch %></span>
      <% end %>
      <span id="server-status">
        <span class="dot"></span>
        <span class="label">Server offline</span>
      </span>
    </div>
  </div>

  <script>
    var require = {
      paths: { vs: "<%= qedit.monaco_path("min/vs") %>" }
    };
  </script>
  <script src="<%= qedit.monaco_path("min/vs/loader.js") %>"></script>
  <script>
    (function() {
      'use strict';

      const BASE      = "<%= j(qedit.root_path.chomp('/')) %>";
      const FILES_URL = BASE + "/files";
      const FILE_URL  = BASE + "/file";
      const LINT_URL  = BASE + "/lint";
      const PING_URL  = BASE + "/ping";

      let monacoEditor = null;

      // Tab state
      // tabs: Array<{ path: string, model: ITextModel, dirty: boolean }>
      let tabs      = [];
      let activeTab = null;

      const elCurrentFile = document.getElementById('current-file');
      const elStatusMsg   = document.getElementById('status-msg');
      const elBtnSave     = document.getElementById('btn-save');
      const elTree        = document.getElementById('file-tree');
      const elEditorDiv   = document.getElementById('monaco-editor');
      const elPlaceholder = document.getElementById('editor-placeholder');
      const elLoading     = document.getElementById('loading-overlay');
      const elTabBar      = document.getElementById('tab-bar');

      // ── Monaco init ──────────────────────────────────────────────────
      window.MonacoEnvironment = {
        getWorkerUrl: function(moduleId, label) {
          const assetsBase = "<%= qedit.monaco_path("min/vs/assets") %>";
          if (label === 'json')       return assetsBase + '/json.worker.js';
          if (label === 'css' || label === 'scss' || label === 'less')
                                      return assetsBase + '/css.worker.js';
          if (label === 'html' || label === 'handlebars' || label === 'razor')
                                      return assetsBase + '/html.worker.js';
          if (label === 'typescript' || label === 'javascript')
                                      return assetsBase + '/ts.worker.js';
          return assetsBase + '/editor.worker.js';
        }
      };

      require(['vs/editor/editor.main'], function() {
        monaco.editor.defineTheme('qedit-dark', {
          base: 'vs-dark',
          inherit: true,
          rules: [],
          colors: { 'editor.background': '#1e1e1e' }
        });

        monacoEditor = monaco.editor.create(elEditorDiv, {
          theme: 'qedit-dark',
          automaticLayout: true,
          fontSize: 13,
          lineNumbers: 'on',
          minimap: { enabled: true },
          scrollBeyondLastLine: false,
          wordWrap: 'off',
        });

        monacoEditor.onDidChangeModelContent(function() {
          if (activeTab && !activeTab.dirty) {
            activeTab.dirty = true;
            renderTabs();
            elBtnSave.disabled = false;
          }
          if (activeTab) {
            clearTimeout(activeTab.lintTimer);
            activeTab.lintTimer = setTimeout(function() { lintModel(activeTab); }, 600);
          }
        });

        monacoEditor.addCommand(
          monaco.KeyMod.CtrlCmd | monaco.KeyCode.KeyS,
          saveCurrentFile
        );

        loadFileTree();
      });

      // ── Tab rendering ────────────────────────────────────────────────
      function renderTabs() {
        elTabBar.innerHTML = '';
        tabs.forEach(function(tab) {
          const el = document.createElement('div');
          el.className = 'tab' + (tab === activeTab ? ' active' : '');
          el.dataset.path = tab.path;

          const nameEl = document.createElement('span');
          nameEl.className = 'tab-name';
          nameEl.textContent = tab.path.split('/').pop();
          nameEl.title = tab.path;

          const closeEl = document.createElement('span');
          closeEl.className = 'tab-close';
          closeEl.textContent = '×';
          closeEl.addEventListener('click', function(e) {
            closeTab(tab, e);
          });

          el.appendChild(nameEl);
          if (tab.dirty) {
            const dirtyEl = document.createElement('span');
            dirtyEl.className = 'tab-dirty';
            dirtyEl.textContent = '●';
            el.appendChild(dirtyEl);
          }
          el.appendChild(closeEl);

          el.addEventListener('click', function() {
            switchToTab(tab);
          });

          elTabBar.appendChild(el);
        });
      }

      // ── Tab management ───────────────────────────────────────────────
      function switchToTab(tab) {
        activeTab = tab;
        monacoEditor.setModel(tab.model);

        elPlaceholder.style.display = 'none';
        elEditorDiv.style.display   = 'block';

        elCurrentFile.textContent = tab.path;
        elBtnSave.disabled = !tab.dirty;
        setStatus('');

        // Sync sidebar highlight
        document.querySelectorAll('.tree-item.active').forEach(function(e) {
          e.classList.remove('active');
        });
        const sidebarItem = elTree.querySelector('[data-path="' + tab.path + '"]');
        if (sidebarItem) sidebarItem.classList.add('active');

        renderTabs();
        // Scroll active tab into view
        const activeEl = elTabBar.querySelector('.tab.active');
        if (activeEl) activeEl.scrollIntoView({ inline: 'nearest' });

        lintModel(tab);
      }

      function closeTab(tab, event) {
        event.stopPropagation();
        if (tab.dirty) {
          if (!confirm('Discard unsaved changes to ' + tab.path.split('/').pop() + '?')) return;
        }

        clearTimeout(tab.lintTimer);
        tab.model.dispose();
        const idx = tabs.indexOf(tab);
        tabs.splice(idx, 1);

        if (tab === activeTab) {
          if (tabs.length > 0) {
            // Prefer the tab to the right, fall back to left
            switchToTab(tabs[idx] || tabs[idx - 1]);
          } else {
            activeTab = null;
            elPlaceholder.style.display = '';
            elEditorDiv.style.display   = 'none';
            elCurrentFile.textContent   = 'No file open';
            elBtnSave.disabled          = true;
            setStatus('');
            document.querySelectorAll('.tree-item.active').forEach(function(e) {
              e.classList.remove('active');
            });
            renderTabs();
          }
        } else {
          renderTabs();
        }
      }

      // ── File tree ────────────────────────────────────────────────────
      function loadFileTree() {
        fetch(FILES_URL)
          .then(r => r.json())
          .then(tree => {
            elTree.innerHTML = '';
            renderTree(tree, elTree, 0);
          })
          .catch(() => {
            elTree.innerHTML = '<div class="tree-item" style="color:#f44;">Failed to load files</div>';
            setServerStatus(false);
          });
      }

      function renderTree(nodes, container, depth) {
        nodes.forEach(function(node) {
          if (node.type === 'directory') {
            const wrapper = document.createElement('div');
            wrapper.className = 'tree-dir';

            const header = document.createElement('div');
            header.className = 'tree-item';
            header.style.paddingLeft = (8 + depth * 14) + 'px';
            header.innerHTML =
              '<span class="icon">▶</span>' +
              '<span class="name">' + escHtml(node.name) + '</span>';
            header.addEventListener('click', function() {
              wrapper.classList.toggle('open');
              header.querySelector('.icon').textContent =
                wrapper.classList.contains('open') ? '▼' : '▶';
            });

            const children = document.createElement('div');
            children.className = 'tree-children';
            renderTree(node.children || [], children, depth + 1);

            wrapper.appendChild(header);
            wrapper.appendChild(children);
            container.appendChild(wrapper);
          } else {
            const item = document.createElement('div');
            item.className = 'tree-item';
            item.style.paddingLeft = (8 + depth * 14) + 'px';
            item.dataset.path = node.path;
            item.innerHTML =
              '<span class="icon">·</span>' +
              '<span class="name">' + escHtml(node.name) + '</span>';
            item.addEventListener('click', function() {
              openFile(node.path, item);
            });
            container.appendChild(item);
          }
        });
      }

      // ── File open / save ─────────────────────────────────────────────
      function openFile(path) {
        // If already open, just switch to that tab
        const existing = tabs.find(function(t) { return t.path === path; });
        if (existing) {
          switchToTab(existing);
          return;
        }

        elLoading.classList.add('visible');
        setStatus('');

        fetch(FILE_URL + '?path=' + encodeURIComponent(path))
          .then(r => r.json())
          .then(data => {
            if (data.error) { setStatus('Error: ' + data.error, true); return; }

            const model = monaco.editor.createModel(data.content, data.language);
            const tab   = { path: path, model: model, dirty: false, lintTimer: null };
            tabs.push(tab);
            switchToTab(tab);
          })
          .catch(() => { setStatus('Failed to load file', true); setServerStatus(false); })
          .finally(() => elLoading.classList.remove('visible'));
      }

      function lintModel(tab) {
        if (!tab || !tab.model) return;
        if (!tab.path.match(/\.rb$/)) {
          monaco.editor.setModelMarkers(tab.model, 'rubocop', []);
          return;
        }
        fetch(LINT_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ path: tab.path, content: tab.model.getValue() }).toString()
        })
          .then(function(r) { return r.json(); })
          .then(function(diagnostics) {
            if (tab.model.isDisposed()) return;
            monaco.editor.setModelMarkers(tab.model, 'rubocop', diagnostics.map(function(d) {
              return {
                startLineNumber: d.line,
                startColumn:     d.column,
                endLineNumber:   d.line,
                endColumn:       d.endColumn,
                message:         d.message,
                severity:        d.severity
              };
            }));
          })
          .catch(function() { setServerStatus(false); });
      }

      function saveCurrentFile() {
        if (!activeTab || !monacoEditor) return;
        elBtnSave.disabled = true;
        setStatus('Saving…');

        const body = new URLSearchParams({
          path:    activeTab.path,
          content: monacoEditor.getValue()
        });

        fetch(FILE_URL, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString()
        })
          .then(r => r.json())
          .then(data => {
            if (data.ok) {
              activeTab.dirty = false;
              renderTabs();
              setStatus('Saved ✓');
              setTimeout(() => setStatus(''), 2000);
            } else {
              setStatus('Error: ' + (data.error || 'unknown'), true);
              elBtnSave.disabled = false;
            }
          })
          .catch(() => {
            setStatus('Save failed', true);
            elBtnSave.disabled = false;
            setServerStatus(false);
          });
      }

      elBtnSave.addEventListener('click', saveCurrentFile);

      // ── Helpers ──────────────────────────────────────────────────────
      function setStatus(msg, isError) {
        elStatusMsg.textContent = msg;
        elStatusMsg.style.color = isError ? '#f48771' : '#4ec9b0';
      }

      // ── Server status ─────────────────────────────────────────────────
      const elServerStatus = document.getElementById('server-status');

      function setServerStatus(online) {
        if (online) {
          elServerStatus.classList.remove('offline');
        } else {
          elServerStatus.classList.add('offline');
        }
      }

      function pollServer() {
        fetch(PING_URL, { method: 'GET', cache: 'no-store' })
          .then(function(r) { setServerStatus(r.ok); })
          .catch(function()  { setServerStatus(false); });
      }

      pollServer();
      setInterval(pollServer, 10000);

      function escHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }
    })();
  </script>
</body>
</html>
